function cleanData(sheetName) {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(sheetName);
  if (!sheet) return [];
  const data = sheet.getDataRange().getValues();
  if (data.length <= 1) return [];
  const headers = data[0];
  const result = [];
  
  for (let i = 1; i < data.length; i++) {
    let obj = {};
    for (let j = 0; j < headers.length; j++) {
      let cellValue = data[i][j];
      if (cellValue === null || cellValue === undefined) cellValue = "";
      if (cellValue instanceof Date) {
        cellValue = Utilities.formatDate(cellValue, Session.getScriptTimeZone(), "yyyy-MM-dd");
      }
      obj[headers[j]] = cellValue;
    }
    result.push(obj);
  }
  return result;
}

// --- GENERIC CRUD HELPERS ---
function getFromSheet(sheetName) {
  try { 
    return { success: true, data: cleanData(sheetName) }; 
  } catch (e) { 
    return { success: false, message: e.message }; 
  }
}

function saveToSheet(sheetName, formData) {
  try {
    const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(sheetName);
    const headers = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0];
    
    if (formData.id) {
       const data = sheet.getDataRange().getValues();
       let rowToUpdate = -1;
       for(let i = 1; i < data.length; i++) {
         if(data[i][0] === formData.id) { 
           rowToUpdate = i + 1; 
           break; 
         }
       }
       if(rowToUpdate > -1) {
         const rowData = headers.map(header => formData[header] !== undefined ? formData[header] : "");
         sheet.getRange(rowToUpdate, 1, 1, rowData.length).setValues([rowData]);
       } else {
         const rowData = headers.map(header => formData[header] !== undefined ? formData[header] : "");
         sheet.appendRow(rowData);
       }
    } else {
       formData.id = Utilities.getUuid();
       const rowData = headers.map(header => formData[header] !== undefined ? formData[header] : "");
       sheet.appendRow(rowData);
    }
    return { success: true, message: `Data ${sheetName.replace('_', ' ')} berhasil disimpan.` };
  } catch (e) { 
    return { success: false, message: e.message }; 
  }
}

function deleteFromSheet(sheetName, id) {
  try {
    const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(sheetName);
    const data = sheet.getDataRange().getValues();
    for (let i = 1; i < data.length; i++) {
      if (data[i][0] === id) {
        sheet.deleteRow(i + 1);
        return { success: true, message: 'Data berhasil dihapus.' };
      }
    }
    return { success: false, message: 'Data tidak ditemukan.' };
  } catch (e) { 
    return { success: false, message: e.message }; 
  }
}

// --- SPECIFIC ENDPOINTS ---
function loginUser(username, password) {
  try {
    const users = cleanData('Users');
    const user = users.find(u => u.username === username && u.password === password);
    if (user) {
      return { success: true, user: { username: user.username, nama: user.nama, role: user.role } };
    }
    return { success: false, message: 'Username atau password salah!' };
  } catch (e) { 
    return { success: false, message: e.message }; 
  }
}

function getProfil() {
  try {
    const data = cleanData('Profil_Instansi');
    return { success: true, data: data.length > 0 ? data[0] : null };
  } catch (e) { 
    return { success: false, message: e.message }; 
  }
}

function saveProfil(formData) {
  try {
    const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Profil_Instansi');
    const headers = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0];
    const data = sheet.getDataRange().getValues();
    let rowToUpdate = -1;
    
    for (let i = 1; i < data.length; i++) {
      if (data[i][0] === formData.id) { 
        rowToUpdate = i + 1; 
        break; 
      }
    }
    
    const rowData = headers.map(header => formData[header] !== undefined ? formData[header] : "");
    
    if (rowToUpdate > -1) {
      sheet.getRange(rowToUpdate, 1, 1, rowData.length).setValues([rowData]);
    } else {
      if (!formData.id) formData.id = Utilities.getUuid();
      const newRowData = headers.map(header => formData[header] !== undefined ? formData[header] : "");
      sheet.appendRow(newRowData);
    }
    return { success: true, message: 'Profil Instansi berhasil diperbarui.' };
  } catch (e) { 
    return { success: false, message: e.message }; 
  }
}

