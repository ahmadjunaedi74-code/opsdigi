function importDataBatch(sheetName, dataArray) {
  try {
    const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(sheetName);
    if (!sheet) throw new Error("Sheet tidak ditemukan.");
    
    let lastCol = sheet.getLastColumn();
    if (lastCol === 0) throw new Error("Database kosong. Harap jalankan fungsi Setup Database.");

    const headers = sheet.getRange(1, 1, 1, lastCol).getValues()[0];
    const lowerHeaders = headers.map(h => h.toString().toLowerCase().trim());

    const rowsToInsert = dataArray.map(obj => {
      let normalizedObj = {};
      for (let key in obj) {
        normalizedObj[key.toString().toLowerCase().trim()] = obj[key];
      }
      normalizedObj.id = Utilities.getUuid(); 
      return lowerHeaders.map(header => normalizedObj[header] !== undefined ? normalizedObj[header] : "");
    });

    if (rowsToInsert.length > 0) {
      sheet.getRange(sheet.getLastRow() + 1, 1, rowsToInsert.length, headers.length).setValues(rowsToInsert);
    }
    return { success: true, message: `${rowsToInsert.length} data berhasil diimpor ke ${sheetName.replace('_', ' ')}!` };
  } catch (e) { 
    return { success: false, message: e.message }; 
  }
}